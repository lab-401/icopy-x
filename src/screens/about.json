{
    "id": "about",
    "initial_state": "page1",
    "states": {
        "page1": {
            "screen": {
                "title": "About",
                "page_indicator": "1/3",
                "content": {
                    "type": "text",
                    "lines": [
                        {
                            "text": "{version}",
                            "size": "large",
                            "align": "center"
                        },
                        {
                            "text": ""
                        },
                        {
                            "text": "HW  {hw_ver}"
                        },
                        {
                            "text": "HMI {hmi_ver}"
                        },
                        {
                            "text": "OS  {os_ver}"
                        },
                        {
                            "text": "PM  {pm_ver}"
                        },
                        {
                            "text": "SN  {serial}"
                        }
                    ]
                },
                "buttons": {
                    "left": "",
                    "right": ""
                },
                "keys": {
                    "M1": "noop",
                    "M2": "noop",
                    "OK": "noop",
                    "DOWN": "goto:page2",
                    "PWR": "finish"
                }
            }
        },
        "page2": {
            "screen": {
                "title": "About",
                "page_indicator": "2/3",
                "content": {
                    "type": "text",
                    "lines": [
                        {
                            "text": "Firmware update"
                        },
                        {
                            "text": ""
                        },
                        {
                            "text": "1.Download firmware"
                        },
                        {
                            "text": " icopyx.com/update"
                        },
                        {
                            "text": "2.Plug USB, Copy firmware to device."
                        },
                        {
                            "text": "3.Press 'OK' start update."
                        }
                    ]
                },
                "buttons": {
                    "left": "",
                    "right": ""
                },
                "keys": {
                    "M1": "noop",
                    "M2": "run:checkUpdate",
                    "OK": "run:checkUpdate",
                    "UP": "goto:page1",
                    "DOWN": "goto:page3",
                    "PWR": "finish"
                }
            }
        },
        "page3": {
            "screen": {
                "title": "About",
                "page_indicator": "3/3",
                "content": {
                    "type": "scroller"
                },
                "buttons": {
                    "left": "",
                    "right": ""
                },
                "keys": {
                    "M1": "noop",
                    "M2": "noop",
                    "OK": "noop",
                    "UP": "goto:page2",
                    "PWR": "finish"
                }
            }
        }
    }
}
